<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Menu principal del sitio web Bitatech -->
        <record id="menu_bitatech_inicio" model="website.menu">
            <field name="name">Inicio</field>
            <field name="url">/bitatech</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">10</field>
        </record>

        <record id="menu_bitatech_servicios" model="website.menu">
            <field name="name">Servicios</field>
            <field name="url">/bitatech/servicios</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">20</field>
        </record>

        <record id="menu_bitatech_nosotros" model="website.menu">
            <field name="name">Nosotros</field>
            <field name="url">/bitatech/nosotros</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">30</field>
        </record>

        <record id="menu_bitatech_contacto" model="website.menu">
            <field name="name">Contacto</field>
            <field name="url">/bitatech/contacto</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">40</field>
        </record>

    </data>
</odoo>
