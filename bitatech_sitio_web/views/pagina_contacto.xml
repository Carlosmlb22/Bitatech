<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Pagina de Contacto - Bitatech                                -->
    <!-- URL: /bitatech/contacto                                      -->
    <!-- ============================================================ -->
    <record id="pagina_contacto_bitatech" model="website.page">
        <field name="name">Bitatech - Contacto</field>
        <field name="url">/bitatech/contacto</field>
        <field name="is_published" eval="True"/>
        <field name="website_id" ref="website.default_website"/>
        <field name="view_id" ref="vista_pagina_contacto_bitatech"/>
    </record>

    <record id="vista_pagina_contacto_bitatech" model="ir.ui.view">
        <field name="name">Bitatech - Pagina Contacto</field>
        <field name="type">qweb</field>
        <field name="key">bitatech_sitio_web.vista_pagina_contacto_bitatech</field>
        <field name="arch" type="xml">
            <t t-name="bitatech_sitio_web.vista_pagina_contacto_bitatech" t-call="bitatech_sitio_web.disposicion_bitatech">

                <!-- ===== ENCABEZADO CONTACTO ===== -->
                <section class="bitatech-pagina-encabezado">
                    <div class="bitatech-seccion-interior">
                        <div class="bitatech-animar">
                            <span class="bitatech-etiqueta-seccion">Contacto</span>
                            <h1 class="bitatech-titulo-pagina">Hablemos de tu operacion</h1>
                            <p class="bitatech-desc-pagina">
                                Completa el formulario y nuestro equipo se pondra en contacto
                                contigo en menos de 24 horas habiles.
                            </p>
                        </div>
                    </div>
                </section>

                <!-- ===== CONTENIDO CONTACTO ===== -->
                <section class="bitatech-seccion bitatech-seccion-oscura">
                    <div class="bitatech-seccion-interior">
                        <div class="bitatech-contacto-grid">

                            <!-- Columna izquierda: Formulario -->
                            <div class="bitatech-contacto-formulario bitatech-animar">
                                <h2 class="bitatech-formulario-titulo">Solicita informacion</h2>
                                <form action="/bitatech/contacto/enviar" method="POST"
                                      class="bitatech-formulario" id="formulario_contacto_bitatech">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="bitatech-campo-grupo">
                                        <label for="nombre_completo" class="bitatech-campo-etiqueta">
                                            Nombre completo <span class="bitatech-requerido">*</span>
                                        </label>
                                        <input type="text" id="nombre_completo" name="nombre_completo"
                                               class="bitatech-campo-input" required="required"
                                               placeholder="Tu nombre completo"/>
                                    </div>

                                    <div class="bitatech-campo-fila">
                                        <div class="bitatech-campo-grupo">
                                            <label for="correo" class="bitatech-campo-etiqueta">
                                                Correo electronico <span class="bitatech-requerido">*</span>
                                            </label>
                                            <input type="email" id="correo" name="correo"
                                                   class="bitatech-campo-input" required="required"
                                                   placeholder="correo@empresa.com"/>
                                        </div>
                                        <div class="bitatech-campo-grupo">
                                            <label for="telefono" class="bitatech-campo-etiqueta">
                                                Telefono
                                            </label>
                                            <input type="tel" id="telefono" name="telefono"
                                                   class="bitatech-campo-input"
                                                   placeholder="+507 6000-0000"/>
                                        </div>
                                    </div>

                                    <div class="bitatech-campo-grupo">
                                        <label for="nombre_empresa" class="bitatech-campo-etiqueta">
                                            Empresa
                                        </label>
                                        <input type="text" id="nombre_empresa" name="nombre_empresa"
                                               class="bitatech-campo-input"
                                               placeholder="Nombre de tu empresa"/>
                                    </div>

                                    <div class="bitatech-campo-fila">
                                        <div class="bitatech-campo-grupo">
                                            <label for="servicio_interes" class="bitatech-campo-etiqueta">
                                                Servicio de interes
                                            </label>
                                            <select id="servicio_interes" name="servicio_interes"
                                                    class="bitatech-campo-select">
                                                <option value="otro">Seleccionar servicio</option>
                                                <option value="erp">Implementacion ERP</option>
                                                <option value="automatizacion">Automatizacion Avanzada</option>
                                                <option value="chat">Sistemas de Chat y Conversion</option>
                                                <option value="optimizacion">Optimizacion Operativa</option>
                                                <option value="desarrollo">Desarrollo a Medida</option>
                                                <option value="otro">Otro / No estoy seguro</option>
                                            </select>
                                        </div>
                                        <div class="bitatech-campo-grupo">
                                            <label for="cantidad_empleados" class="bitatech-campo-etiqueta">
                                                Cantidad de empleados
                                            </label>
                                            <select id="cantidad_empleados" name="cantidad_empleados"
                                                    class="bitatech-campo-select">
                                                <option value="">Seleccionar rango</option>
                                                <option value="1-5">1 a 5 empleados</option>
                                                <option value="6-15">6 a 15 empleados</option>
                                                <option value="16-50">16 a 50 empleados</option>
                                                <option value="51-200">51 a 200 empleados</option>
                                                <option value="200+">Mas de 200 empleados</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="bitatech-campo-grupo">
                                        <label for="mensaje" class="bitatech-campo-etiqueta">
                                            ¿En que podemos ayudarte?
                                        </label>
                                        <textarea id="mensaje" name="mensaje"
                                                  class="bitatech-campo-textarea" rows="5"
                                                  placeholder="Describe brevemente tu situacion actual y que necesitas resolver..."></textarea>
                                    </div>

                                    <button type="submit" class="bitatech-btn bitatech-btn-primario bitatech-btn-formulario">
                                        Enviar Solicitud
                                    </button>
                                </form>
                            </div>

                            <!-- Columna derecha: Info de contacto + proceso -->
                            <div class="bitatech-contacto-info bitatech-animar" data-delay="200">

                                <!-- Info directa -->
                                <div class="bitatech-info-bloque">
                                    <h3>Informacion de contacto</h3>
                                    <ul class="bitatech-info-lista">
                                        <li>
                                            <i class="fa fa-envelope"></i>
                                            <div>
                                                <strong>Correo</strong>
                                                <a href="mailto:info@bitatech.co">info@bitatech.co</a>
                                            </div>
                                        </li>
                                        <li>
                                            <i class="fa fa-phone"></i>
                                            <div>
                                                <strong>Telefono</strong>
                                                <span>+507 6000-0000</span>
                                            </div>
                                        </li>
                                        <li>
                                            <i class="fa fa-map-marker"></i>
                                            <div>
                                                <strong>Ubicacion</strong>
                                                <span>Panama, Panama</span>
                                            </div>
                                        </li>
                                        <li>
                                            <i class="fa fa-clock-o"></i>
                                            <div>
                                                <strong>Horario</strong>
                                                <span>Lunes a Viernes, 9:00 AM - 6:00 PM</span>
                                            </div>
                                        </li>
                                    </ul>
                                </div>

                                <!-- Proceso de 3 pasos -->
                                <div class="bitatech-info-bloque bitatech-proceso-bloque">
                                    <h3>¿Como funciona?</h3>
                                    <div class="bitatech-pasos-mini">
                                        <div class="bitatech-paso-mini">
                                            <div class="bitatech-paso-mini-numero">1</div>
                                            <div>
                                                <strong>Envias tu solicitud</strong>
                                                <p>Completa el formulario con tu informacion basica.</p>
                                            </div>
                                        </div>
                                        <div class="bitatech-paso-mini">
                                            <div class="bitatech-paso-mini-numero">2</div>
                                            <div>
                                                <strong>Diagnostico inicial</strong>
                                                <p>Agendamos una llamada para entender tu operacion.</p>
                                            </div>
                                        </div>
                                        <div class="bitatech-paso-mini">
                                            <div class="bitatech-paso-mini-numero">3</div>
                                            <div>
                                                <strong>Propuesta estructurada</strong>
                                                <p>Recibes un plan claro con alcance, tiempos y costos.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </section>

            </t>
        </field>
    </record>

</odoo>
