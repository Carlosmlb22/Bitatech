<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Vistas Backend: Solicitudes de Contacto                      -->
    <!-- ============================================================ -->

    <!-- ===== VISTA KANBAN ===== -->
    <record id="vista_kanban_solicitud_contacto" model="ir.ui.view">
        <field name="name">bitatech.solicitud.contacto.kanban</field>
        <field name="model">bitatech.solicitud.contacto</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado" class="o_kanban_small_column">
                <field name="nombre_completo"/>
                <field name="correo"/>
                <field name="telefono"/>
                <field name="nombre_empresa"/>
                <field name="servicio_interes"/>
                <field name="estado"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="nombre_completo"/>
                                    </strong>
                                </div>
                            </div>
                            <div t-if="record.nombre_empresa.raw_value" class="text-muted small">
                                <i class="fa fa-building me-1"/>
                                <field name="nombre_empresa"/>
                            </div>
                            <div class="text-muted small">
                                <i class="fa fa-envelope me-1"/>
                                <field name="correo"/>
                            </div>
                            <div t-if="record.telefono.raw_value" class="text-muted small">
                                <i class="fa fa-phone me-1"/>
                                <field name="telefono"/>
                            </div>
                            <div class="mt-1">
                                <field name="servicio_interes" widget="badge"
                                       decoration-info="servicio_interes == 'erp'"
                                       decoration-warning="servicio_interes == 'automatizacion'"
                                       decoration-success="servicio_interes == 'chat'"
                                       decoration-primary="servicio_interes == 'optimizacion'"
                                       decoration-danger="servicio_interes == 'desarrollo'"/>
                            </div>
                            <div class="text-muted small mt-1">
                                <i class="fa fa-calendar me-1"/>
                                <field name="create_date" widget="date"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===== VISTA LISTA ===== -->
    <record id="vista_lista_solicitud_contacto" model="ir.ui.view">
        <field name="name">bitatech.solicitud.contacto.list</field>
        <field name="model">bitatech.solicitud.contacto</field>
        <field name="arch" type="xml">
            <list decoration-info="estado == 'nuevo'"
                  decoration-warning="estado == 'contactado'"
                  decoration-primary="estado in ('diagnostico', 'propuesta')"
                  decoration-success="estado == 'ganado'"
                  decoration-muted="estado == 'cerrado'">
                <field name="create_date" string="Fecha" widget="date"/>
                <field name="nombre_completo"/>
                <field name="correo"/>
                <field name="telefono" optional="show"/>
                <field name="nombre_empresa" optional="show"/>
                <field name="servicio_interes"/>
                <field name="cantidad_empleados" optional="hide"/>
                <field name="origen" optional="hide"/>
                <field name="estado" widget="badge"
                       decoration-info="estado == 'nuevo'"
                       decoration-warning="estado == 'contactado'"
                       decoration-primary="estado in ('diagnostico', 'propuesta')"
                       decoration-success="estado == 'ganado'"
                       decoration-muted="estado == 'cerrado'"/>
                <field name="oportunidad_crm_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ===== VISTA FORMULARIO ===== -->
    <record id="vista_formulario_solicitud_contacto" model="ir.ui.view">
        <field name="name">bitatech.solicitud.contacto.form</field>
        <field name="model">bitatech.solicitud.contacto</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="nuevo,contactado,diagnostico,propuesta,ganado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre_completo" placeholder="Nombre completo"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos de Contacto">
                            <field name="correo" widget="email"/>
                            <field name="telefono" widget="phone"/>
                            <field name="nombre_empresa"/>
                            <field name="cantidad_empleados"/>
                        </group>
                        <group string="Clasificacion">
                            <field name="servicio_interes"/>
                            <field name="origen"/>
                            <field name="oportunidad_crm_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mensaje" name="pagina_mensaje">
                            <group>
                                <field name="mensaje" nolabel="1" placeholder="Mensaje del cliente..."/>
                            </group>
                        </page>
                        <page string="Notas Internas" name="pagina_notas">
                            <group>
                                <field name="notas_internas" nolabel="1" placeholder="Notas internas del equipo..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ===== VISTA BUSQUEDA ===== -->
    <record id="vista_busqueda_solicitud_contacto" model="ir.ui.view">
        <field name="name">bitatech.solicitud.contacto.search</field>
        <field name="model">bitatech.solicitud.contacto</field>
        <field name="arch" type="xml">
            <search>
                <field name="nombre_completo"/>
                <field name="correo"/>
                <field name="nombre_empresa"/>
                <field name="telefono"/>
                <filter name="filtro_nuevos" string="Nuevos"
                        domain="[('estado', '=', 'nuevo')]"/>
                <filter name="filtro_contactados" string="Contactados"
                        domain="[('estado', '=', 'contactado')]"/>
                <filter name="filtro_diagnostico" string="En Diagnostico"
                        domain="[('estado', '=', 'diagnostico')]"/>
                <filter name="filtro_propuesta" string="Propuesta"
                        domain="[('estado', '=', 'propuesta')]"/>
                <filter name="filtro_ganados" string="Ganados"
                        domain="[('estado', '=', 'ganado')]"/>
                <separator/>
                <filter name="filtro_sitio_web" string="Desde Sitio Web"
                        domain="[('origen', '=', 'sitio_web')]"/>
                <separator/>
                <group string="Agrupar por">
                    <filter name="agrupar_estado" string="Estado"
                            context="{'group_by': 'estado'}"/>
                    <filter name="agrupar_servicio" string="Servicio"
                            context="{'group_by': 'servicio_interes'}"/>
                    <filter name="agrupar_origen" string="Origen"
                            context="{'group_by': 'origen'}"/>
                    <filter name="agrupar_fecha" string="Fecha"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ===== ACCION ===== -->
    <record id="accion_solicitud_contacto" model="ir.actions.act_window">
        <field name="name">Solicitudes de Contacto</field>
        <field name="res_model">bitatech.solicitud.contacto</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="vista_busqueda_solicitud_contacto"/>
        <field name="context">{'default_origen': 'sitio_web', 'search_default_filtro_nuevos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de contacto todavia
            </p>
            <p>
                Las solicitudes aparecen aqui cuando un visitante
                completa el formulario en el sitio web de Bitatech.
            </p>
        </field>
    </record>

</odoo>
