<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- SNIPPET: Llamado a Diagnostico BSI                            -->
    <!-- ============================================================ -->
    <template id="snippet_llamado_diagnostico" name="Llamado Diagnostico BSI">
        <section class="bitatech-llamado-snippet">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8 text-center">
                        <div class="bitatech-llamado">
                            <p class="bitatech-llamado__etiqueta">BITATECH</p>
                            <h2 class="bitatech-llamado__titulo">
                                Tu empresa merece un sistema
                                que trabaje para ti
                            </h2>
                            <p class="bitatech-llamado__texto">
                                Agenda un Diagnostico BSI gratuito y descubre como eliminar
                                el caos operativo de tu negocio.
                            </p>
                            <a href="/bitatech#seccion_formulario"
                               class="bitatech-llamado__boton">
                                Agendar Diagnostico BSI&#8482;
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <style>
                .bitatech-llamado-snippet {
                    padding: 80px 0;
                    background: linear-gradient(135deg, #0f1923, #162231);
                }
                .bitatech-llamado {
                    padding: 48px 40px;
                    background: linear-gradient(135deg, #162231, rgba(200, 144, 62, 0.06));
                    border: 1px solid rgba(200, 144, 62, 0.2);
                    border-radius: 12px;
                }
                .bitatech-llamado__etiqueta {
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 3px;
                    color: #c8903e;
                    margin-bottom: 12px;
                }
                .bitatech-llamado__titulo {
                    font-size: 32px;
                    font-weight: 800;
                    color: #ffffff;
                    margin-bottom: 16px;
                    line-height: 1.2;
                }
                .bitatech-llamado__texto {
                    font-size: 16px;
                    color: #8899aa;
                    max-width: 480px;
                    margin: 0 auto 28px;
                    line-height: 1.6;
                }
                .bitatech-llamado__boton {
                    display: inline-block;
                    padding: 16px 40px;
                    background: #c8903e;
                    color: #ffffff;
                    font-size: 15px;
                    font-weight: 600;
                    border-radius: 8px;
                    text-decoration: none;
                    transition: all 0.3s ease;
                }
                .bitatech-llamado__boton:hover {
                    background: #daa050;
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(200, 144, 62, 0.35);
                    color: #ffffff;
                    text-decoration: none;
                }
                @media (max-width: 767px) {
                    .bitatech-llamado {
                        padding: 32px 20px;
                    }
                    .bitatech-llamado__titulo {
                        font-size: 24px;
                    }
                }
            </style>
        </section>
    </template>

    <!-- Registrar snippet en el editor web -->
    <template id="llamado_diagnostico_opciones"
              inherit_id="website.snippets" name="Llamado Diagnostico - Opcion Editor">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="bitatech_sitio_web.snippet_llamado_diagnostico"
               t-thumbnail="/bitatech_sitio_web/static/src/img/snippet_llamado_thumb.png"/>
        </xpath>
    </template>

</odoo>
