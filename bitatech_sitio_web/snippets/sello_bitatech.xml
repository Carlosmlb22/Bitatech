<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- SNIPPET: Sello Bitatech (para footer u otras paginas)         -->
    <!-- ============================================================ -->
    <template id="snippet_sello_bitatech" name="Sello Bitatech">
        <section class="bitatech-sello-snippet">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8 text-center">
                        <div class="bitatech-sello">
                            <div class="bitatech-sello__linea"></div>
                            <div class="bitatech-sello__contenido">
                                <h4 class="bitatech-sello__marca">BITATECH</h4>
                                <p class="bitatech-sello__tagline">Sistemas Empresariales Inteligentes</p>
                                <p class="bitatech-sello__metodo">Metodo BSI&#8482;</p>
                            </div>
                            <div class="bitatech-sello__linea"></div>
                        </div>
                    </div>
                </div>
            </div>
            <style>
                .bitatech-sello-snippet {
                    padding: 40px 0;
                    background: #0a0f14;
                }
                .bitatech-sello {
                    display: flex;
                    align-items: center;
                    gap: 24px;
                    justify-content: center;
                }
                .bitatech-sello__linea {
                    flex: 1;
                    max-width: 120px;
                    height: 1px;
                    background: linear-gradient(90deg, transparent, #c8903e, transparent);
                }
                .bitatech-sello__contenido {
                    text-align: center;
                }
                .bitatech-sello__marca {
                    font-size: 18px;
                    font-weight: 800;
                    color: #c8903e;
                    letter-spacing: 4px;
                    margin-bottom: 4px;
                }
                .bitatech-sello__tagline {
                    font-size: 12px;
                    color: #8899aa;
                    letter-spacing: 2px;
                    margin-bottom: 2px;
                }
                .bitatech-sello__metodo {
                    font-size: 11px;
                    color: #556677;
                    letter-spacing: 1px;
                    margin: 0;
                }
            </style>
        </section>
    </template>

    <!-- Registrar snippet en el editor web -->
    <template id="sello_bitatech_opciones"
              inherit_id="website.snippets" name="Sello Bitatech - Opcion Editor">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="bitatech_sitio_web.snippet_sello_bitatech"
               t-thumbnail="/bitatech_sitio_web/static/src/img/snippet_sello_thumb.png"/>
        </xpath>
    </template>

</odoo>
